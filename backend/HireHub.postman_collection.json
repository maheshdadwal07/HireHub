{
	"info": {
		"_postman_id": "hirehub-collection-id",
		"name": "HireHub API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register Recruiter",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"John Recruiter\",\n    \"email\": \"john@company.com\",\n    \"password\": \"password123\",\n    \"role\": \"RECRUITER\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/register",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"auth",
								"register"
							]
						}
					}
				},
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"john@company.com\",\n    \"password\": \"password123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"auth",
								"login"
							]
						}
					}
				}
			]
		},
		{
			"name": "Company",
			"item": [
				{
					"name": "Create Company",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Tech Corp\",\n    \"description\": \"A leading tech firm\",\n    \"location\": \"San Francisco\",\n    \"website\": \"https://techcorp.com\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/companies",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"companies"
							]
						}
					}
				},
				{
					"name": "Get All Companies",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/companies?page=1&limit=10",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"companies"
							],
							"query": [
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "limit",
									"value": "10"
								}
							]
						}
					}
				}
			]
		},
		{
			"name": "Job",
			"item": [
				{
					"name": "Post Job",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Senior Node.js Developer\",\n    \"description\": \"Responsible for building scalable APIs\",\n    \"location\": \"Remote\",\n    \"employmentType\": \"FULL_TIME\",\n    \"experienceLevel\": \"SENIOR\",\n    \"salaryMin\": 80000,\n    \"salaryMax\": 120000,\n    \"companyId\": 1\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/jobs",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"jobs"
							]
						}
					}
				},
				{
					"name": "Get All Jobs (Search/Filter)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/jobs?search=Node&location=Remote",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"jobs"
							],
							"query": [
								{
									"key": "search",
									"value": "Node"
								},
								{
									"key": "location",
									"value": "Remote"
								}
							]
						}
					}
				}
			]
		},
		{
			"name": "Application",
			"item": [
				{
					"name": "Apply for Job",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"coverLetter\": \"I love building products\",\n    \"resumeUrl\": \"https://resume.com/john\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/applications/apply/1",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"applications",
								"apply",
								"1"
							]
						}
					}
				},
				{
					"name": "Update Application Status",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"status\": \"SHORTLISTED\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/applications/1/status",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"applications",
								"1",
								"status"
							]
						}
					}
				}
			]
		}
	],
